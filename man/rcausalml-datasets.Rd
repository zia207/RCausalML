\name{rcausalml-datasets}
\alias{rcausalml-datasets}
\alias{LBC_data}
\alias{diabetes}
\alias{ihdp_npci_3}
\alias{sachs_data}
\alias{sachs_labels}
\title{Datasets included with RCausalML}
\description{
Reference documentation for datasets shipped with RCausalML.
}
\format{
These objects are provided as standard R dataset objects.
}
\details{
\itemize{
  \item \code{LBC_data}: benchmark/sample dataset used by package examples.
  \item \code{diabetes}: diabetes benchmark dataset used in examples/tests.
  \item \code{ihdp_npci_3}: IHDP semi-synthetic benchmark data.
  \item \code{sachs_data}: Sachs network data matrix used for DAG/causal structure experiments.
  \item \code{sachs_labels}: variable names for \code{sachs_data}.
}
}
\seealso{
\code{\link{synthetic_data}},
\code{\link{causalStructureML}}
}
\keyword{datasets}
